ASANA_ACCESS_TOKEN=your_asana_pat
ASANA_PROJECT_URL=https://app.asana.com/0/1234567890123456/list

# Optional: keep all tasks in one fixed section (legacy mode)
# ASANA_SECTION_NAME=Inbox

# Optional: status-based section routing is enabled by default.
# Set to false only when forcing legacy single-section mode.
ASANA_USE_STATUS_SECTIONS=true

# Optional: map specific statuses to preferred section names
# ASANA_STATUS_SECTION_MAP_JSON={"手動ローンチ実行待ち":"要対応","分離済み":"完了"}

# Optional: source repo location overrides
SOURCE_REPO_PATH=./source-bussines-idea
SOURCE_REPO_URL=https://github.com/akina910/bussines_idea
